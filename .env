# ============================================================
# Phase 1 数据库连接配置
# ============================================================
# 切换目标数据库: mssql | kingbasees | dm8
APP_ACTIVE_DB=mssql

# ----------------------------------------------------------
# MSSQL (SQL Server 2019+)
# ----------------------------------------------------------
APP_MSSQL_HOST=localhost
APP_MSSQL_PORT=1433
APP_MSSQL_DATABASE=demo_db
APP_MSSQL_USER=sa
APP_MSSQL_PASSWORD=YourStrong!Passw0rd

# ----------------------------------------------------------
# KingbaseES (人大金仓) — PostgreSQL 协议端口 54321
# ----------------------------------------------------------
APP_KINGBASEES_HOST=localhost
APP_KINGBASEES_PORT=54321
APP_KINGBASEES_DATABASE=demo_db
APP_KINGBASEES_USER=system
APP_KINGBASEES_PASSWORD=123456

# ----------------------------------------------------------
# DM8 (达梦) — 默认端口 5236
# ----------------------------------------------------------
APP_DM8_HOST=localhost
APP_DM8_PORT=5236
APP_DM8_DATABASE=demo_db
APP_DM8_USER=SYSDBA
APP_DM8_PASSWORD=SYSDBA001

# ----------------------------------------------------------
# CI 控制（可选）
# ----------------------------------------------------------
# KINGBASEES_AVAILABLE=1
# DM8_AVAILABLE=1
